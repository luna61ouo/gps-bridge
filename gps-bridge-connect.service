[Unit]
Description=gps-bridge GPS relay connector
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Token is stored in ~/.gps-bridge/config.json (saved on first `gps-bridge connect --token <TOKEN>`)
# No EnvironmentFile or connect.env needed.
# Replace the path below with the output of: which gps-bridge
# Replace YOUR_NAME with the tracker name used during pairing (e.g. Luna, Alice)
ExecStart=/usr/local/bin/gps-bridge connect --name YOUR_NAME
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
